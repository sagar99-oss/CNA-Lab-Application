pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
                echo "Workspace: ${WORKSPACE}"
            }
        }

        stage('Verify Project Structure') {
            steps {
                script {
                    def requiredFiles = [
                        'todo-app/package.json',
                        'todo-app/Dockerfile',
                        'todo-app/docker-compose.yml',
                        'todo-app/Jenkinsfile',
                        'todo-app/client/package.json',
                        'todo-app/server/package.json'
                    ]

                    for (file in requiredFiles) {
                        if (!fileExists(file)) {
                            error("Missing file: ${file}")
                        }
                    }

                    echo "All required files found."
                }
            }
        }

        stage('Repository Verification') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'git --version'
                        sh 'pwd'
                        sh 'ls -la'
                    } else {
                        bat 'git --version'
                        bat 'cd'
                        bat 'dir'
                    }
                }
            }
        }

        stage('Pipeline Complete') {
            steps {
                echo '''
==========================================
        BUILD SUCCESSFUL
==========================================

GitHub Repository Verified
Jenkins Pipeline Executed
Project Structure Verified
Docker Configuration Verified
Frontend Folder Found
Backend Folder Found

Experiment 4 Completed Successfully

==========================================
'''
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully.'
        }

        failure {
            echo 'Pipeline execution failed.'
        }
    }
}